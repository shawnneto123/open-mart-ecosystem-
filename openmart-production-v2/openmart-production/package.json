{
  "name": "openmart-supermarket-pro",
  "version": "2.0.0",
  "description": "Production-Ready E-commerce Platform for Nigerian Corner Shops",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "type-check": "tsc --noEmit",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:sync": "npm run build && npx cap sync",
    "cap:build:android": "npm run build && npx cap sync android && npx cap build android",
    "apk:debug": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug && cd ..",
    "apk:release": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease && cd .."
  },
  "dependencies": {
    "@capacitor/android": "^5.7.0",
    "@capacitor/app": "^5.0.6",
    "@capacitor/core": "^5.7.0",
    "@capacitor/haptics": "^5.0.6",
    "@capacitor/ios": "^5.7.0",
    "@capacitor/keyboard": "^5.0.6",
    "@capacitor/splash-screen": "^5.0.6",
    "@capacitor/status-bar": "^5.0.6",
    "@hookform/resolvers": "^3.3.4",
    "@supabase/supabase-js": "^2.110.2",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.4",
    "html5-qrcode": "^2.3.8",
    "idb": "^8.0.0",
    "lucide-react": "^0.292.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.48.0",
    "react-router-dom": "^6.20.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "zustand": "^4.4.1",
    "@paystack/inline-js": "^2.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "terser": "^5.49.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.3.0"
  }
}
