# ============================================
# OPEN MART APP — Root .gitignore
# ============================================

# Dependencies — never track these
node_modules/
**/node_modules/

# Production builds
dist/
build/
**/dist/
**/build/

# Android build outputs
android/app/build/
**/android/app/build/
**/*.apk
**/*.aab

# Environment secrets — NEVER commit these
.env
.env.local
.env.production
.env.development
**/.env
**/.env.local
**/.env.production

# Vite / PWA cache
**/.vite/
**/vite.config.ts.timestamp*

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor configs
.vscode/settings.json
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Zip archives (already tracked separately)
*.zip

# Capacitor generated files (keep android/ structure, not build output)
android/.gradle/
android/build/
ios/Pods/
ios/build/
